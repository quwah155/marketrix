# ================================
# APP CONFIGURATION
# ================================
# For local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For Vercel production — set this to your actual deployment URL:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ================================
# DATABASE (MongoDB)
# ================================
# Example: mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/quwahmarket?retryWrites=true&w=majority
MONGODB_URI="mongodb://USER:PASSWORD@localhost:27017/quwahmarket"

# ================================
# NEXTAUTH CONFIG
# ================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-long-random-secret

# CRITICAL for production: must be your EXACT deployment URL (no trailing slash)
# Vercel: https://your-app.vercel.app
# Custom domain: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ================================
# GOOGLE OAUTH (NextAuth)
# ================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Also add this to Google Cloud Console > Authorized redirect URIs:
# https://your-app.vercel.app/api/auth/callback/google

# ================================
# STRIPE (TEST MODE)
# ================================
# From Stripe dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Webhook secret from Stripe CLI or dashboard
# WARNING: No leading/trailing spaces! Must start exactly with "whsec_"
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# ================================
# EMAIL (SMTP / Nodemailer)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-character-app-password
EMAIL_FROM=your@gmail.com

# ================================
# REAL-TIME (Pusher)
# ================================
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=mt1

NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ================================
# FILE UPLOADS (UploadThing)
# ================================
UPLOADTHING_TOKEN=your-uploadthing-token

# ================================
# OPTIONAL (REDIS - rate limiting / caching)
# ================================
REDIS_URL=redis://default:password@host:port

# ================================
# VERCEL DEPLOYMENT CHECKLIST
# ================================
# In Vercel Dashboard > Project Settings > Environment Variables, set:
#
#   NEXT_PUBLIC_APP_URL   = https://your-app.vercel.app  (or custom domain)
#   NEXTAUTH_URL          = https://your-app.vercel.app  (or custom domain)
#   NEXTAUTH_SECRET       = (same as local, keep secret)
#   MONGODB_URI           = (your Atlas connection string)
#   GOOGLE_CLIENT_ID      = (real OAuth client ID)
#   GOOGLE_CLIENT_SECRET  = (real OAuth client secret)
#   STRIPE_SECRET_KEY     = (your Stripe secret key)
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = (your Stripe publishable key)
#   STRIPE_WEBHOOK_SECRET = whsec_...  ← NO leading space!
#   PUSHER_APP_ID / PUSHER_KEY / PUSHER_SECRET / PUSHER_CLUSTER
#   NEXT_PUBLIC_PUSHER_KEY / NEXT_PUBLIC_PUSHER_CLUSTER
#   UPLOADTHING_TOKEN     = (your UploadThing token)
#   REDIS_URL             = (optional, Upstash or other Redis URL)
#   SMTP_HOST / SMTP_PORT / SMTP_SECURE / SMTP_USER / SMTP_PASS / EMAIL_FROM
