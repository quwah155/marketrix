# ================================
# APP CONFIGURATION
# ================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ================================
# DATABASE (MongoDB)
# ================================
# Example: mongodb+srv://USER:PASSWORD@cluster0.mongodb.net/quwahmarket?retryWrites=true&w=majority
MONGODB_URI="mongodb://USER:PASSWORD@localhost:27017/quwahmarket"

# ================================
# NEXTAUTH CONFIG
# ================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# ================================
# GOOGLE OAUTH (NextAuth)
# ================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================================
# STRIPE (TEST MODE)
# ================================
# From Stripe dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Webhook secret from Stripe CLI or dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# ================================
# EMAIL (SMTP / Nodemailer)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-character-app-password
EMAIL_FROM=your@gmail.com

# ================================
# REAL-TIME (Pusher)
# ================================
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=mt1

NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ================================
# FILE UPLOADS (UploadThing)
# ================================
UPLOADTHING_TOKEN=your-uploadthing-token

# ================================
# OPTIONAL (REDIS - rate limiting / caching)
# ================================
REDIS_URL=redis://default:password@host:port
